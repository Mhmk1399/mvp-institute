# Copy to `.env` and fill in. Never commit a real `.env`.

# MongoDB connection string (local Docker default below, or use an Atlas URI).
MONGODB_URI="mongodb://localhost:27017/newinstitute"

# Secret used to sign session JWTs. Generate with: openssl rand -base64 32
AUTH_SECRET=""

# AI layer (M1). Provider is currently locked to "openai".
OPENAI_API_KEY=
AI_PROVIDER=openai
# Model ids are supplied only via config — no dated model name is hardcoded.
AI_GENERATION_MODEL=
AI_SCORING_MODEL=
# Optional: dedicated teacher-planner model. Falls back to AI_GENERATION_MODEL.
AI_CLASS_PLANNER_MODEL=
AI_TRANSCRIPTION_MODEL=gpt-realtime-whisper
AI_TRANSCRIPTION_DELAY=minimal

# Standalone realtime gateway.
REALTIME_PORT=3001
REALTIME_ALLOWED_ORIGINS=http://localhost:3000
NEXT_PUBLIC_REALTIME_WS_URL=ws://localhost:3001/ws/class

# Seed accounts for scripts/seed-admin.ts (run with tsx). Not used at runtime.
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD=""
SEED_TEACHER_EMAIL="teacher@example.com"
SEED_TEACHER_PASSWORD=""
